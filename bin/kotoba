#!/usr/bin/env ruby

tool_path = File.expand_path(File.join(File.dirname(__FILE__), "..", "tools", "validators"))
$LOAD_PATH.unshift(tool_path) unless $LOAD_PATH.include?(tool_path)
tool_root = File.expand_path(File.join(File.dirname(__FILE__), "..", "tools"))
$LOAD_PATH.unshift(tool_root) unless $LOAD_PATH.include?(tool_root)

require "catalog_validator"
require "catalog_tools"
require "cli/context"
require "cli/registry"
require "cli/commands"

def usage
  puts "Usage:"
  puts "  bin/kotoba load-test FILE..."
  puts "  bin/kotoba validate [--human] SOURCE_FILE LOCALE_FILE..."
  puts "  bin/kotoba validate-report [--human] SOURCE_FILE LOCALE_FILE... OUTPUT_JSON"
  puts "  bin/kotoba schema catalog|metadata|validation FILE"
  puts "  bin/kotoba pbs-extract NAMESPACE INPUT_PBS OUTPUT_JSON"
  puts "  bin/kotoba messages-dat-extract INPUT_DAT OUTPUT_JSON"
  puts "  bin/kotoba messages-dat-migrate INPUT_DAT NAMESPACE OUTPUT_JSON"
  puts "  bin/kotoba essentials-pairs-import INPUT_TXT NAMESPACE OUTPUT_JSON"
  puts "  bin/kotoba text-english-import INPUT_TXT_OR_DIR NAMESPACE OUTPUT_JSON"
  puts "  bin/kotoba map-rxdata-extract INPUT_RXDATA OUTPUT_JSON"
  puts "  bin/kotoba map-rxdata-import INPUT_RXDATA NAMESPACE OUTPUT_JSON"
  puts "  bin/kotoba flat-export INPUT_JSON OUTPUT_JSON"
  puts "  bin/kotoba flat-import INPUT_JSON OUTPUT_JSON"
  puts "  bin/kotoba spreadsheet-export SOURCE_JSON OUTPUT_CSV [METADATA_JSON] [LOCALE_JSON]"
  puts "  bin/kotoba spreadsheet-import SOURCE_JSON INPUT_CSV OUTPUT_JSON"
  puts "  bin/kotoba pseudo INPUT_JSON OUTPUT_JSON"
  puts "  bin/kotoba tms-export PROFILE LOCALE INPUT_JSON OUTPUT_JSON"
  puts "  bin/kotoba tms-import PROFILE LOCALE INPUT_JSON OUTPUT_JSON"
  puts "  bin/kotoba handoff OUTPUT_DIR LOCALE SOURCE_JSON [METADATA_JSON]"
end

command = ARGV.shift
validator = KotobaTools::CatalogValidator.new
context = KotobaTools::CLIContext.new(validator)

unless command && KotobaTools::CLI.registered?(command)
  usage
  exit 1
end

ok = KotobaTools::CLI.run(command, ARGV, context)

unless ok
  validator.errors.each { |error| warn error }
  usage if validator.errors.empty?
  exit 1
end
