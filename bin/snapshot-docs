#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION="${1:-}"

if [[ -z "$VERSION" ]] || ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "usage: bin/snapshot-docs <semver>" >&2
  echo "  example: bin/snapshot-docs 0.1.0" >&2
  exit 1
fi

DEST="$REPO_ROOT/docs-versions/v$VERSION"
SRC="$REPO_ROOT/docs"

rm -rf "$DEST"
mkdir -p "$DEST"

rsync -a \
  --exclude '.vitepress/dist' \
  --exclude '.vitepress/cache' \
  --exclude '.vitepress/.temp' \
  "$SRC/" "$DEST/"

echo "snapshotted docs/ -> docs-versions/v$VERSION"
