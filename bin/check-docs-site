#!/usr/bin/env bash
set -euo pipefail

DIST="${1:-$(cd "$(dirname "$0")/.." && pwd)/build}"

if [[ ! -d "$DIST" ]]; then
  echo "error: docs site dist not found at $DIST" >&2
  exit 1
fi

errors=0

fail() {
  echo "error: $1" >&2
  errors=$((errors + 1))
}

html_files() {
  find "$DIST" -name '*.html' -type f
}

if [[ ! -f "$DIST/.nojekyll" ]]; then
  fail "dist is missing .nojekyll (GitHub Pages may run Jekyll and break versioned paths)"
fi

while IFS= read -r match; do
  [[ -z "$match" ]] && continue
  fail "doubled site base in $match"
done < <(html_files | xargs grep -l '/kotoba/kotoba/' 2>/dev/null || true)

while IFS= read -r match; do
  [[ -z "$match" ]] && continue
  fail "doubled version path in $match"
done < <(html_files | xargs grep -lE '/v[0-9]+\.[0-9]+\.[0-9]+/v[0-9]+\.[0-9]+\.[0-9]+/' 2>/dev/null || true)

if [[ -f "$DIST/index.html" ]]; then
  if ! grep -qE 'href="/kotoba/v[0-9]+\.[0-9]+\.[0-9]+' "$DIST/index.html" 2>/dev/null; then
    fail "latest build is missing a version picker link to /kotoba/vX.Y.Z/"
  fi
fi

for install_index in "$DIST/essential/installation/index.html" "$DIST"/v*/essential/installation/index.html; do
  [[ -f "$install_index" ]] || fail "missing directory index at ${install_index#$DIST/}"
done

for install_index in "$DIST/essential/installation/index.html" "$DIST"/v*/essential/installation/index.html; do
  [[ -f "$install_index" ]] || continue
  if ! grep -qE 'href="/kotoba/essential/installation' "$install_index" 2>/dev/null && \
     ! grep -qE 'href="/kotoba/v[0-9]+\.[0-9]+\.[0-9]+/essential/installation' "$install_index" 2>/dev/null; then
    fail "$(dirname "$install_index") is missing install guide links"
  fi
done

if [[ "$errors" -gt 0 ]]; then
  exit 1
fi

echo "docs site checks passed ($DIST)"
