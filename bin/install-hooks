#!/usr/bin/env ruby

project_root = File.expand_path("..", File.dirname(__FILE__))

unless File.directory?(File.join(project_root, ".git"))
  warn "Not a git repository: " + project_root
  exit 1
end

Dir.chdir(project_root) do
  candidates = []

  candidates << ["lefthook", "install"] if system("command -v lefthook >/dev/null 2>&1")

  os_arch = `uname`.strip.downcase
  cpu_arch = `uname -m`.strip.gsub("aarch64", "arm64").gsub("x86_64", "x64")
  local_lefthook = File.join("node_modules", "lefthook-#{os_arch}-#{cpu_arch}", "bin", "lefthook")
  candidates << [local_lefthook, "install"] if File.executable?(local_lefthook)

  candidates << ["bun", "run", "hooks:install"] if File.file?("package.json")

  candidates.each do |command|
    if system(*command)
      puts "Installed Lefthook git hooks."
      exit 0
    end
  end

  warn "Could not install Lefthook hooks. Run: bun install && bun run hooks:install"
  exit 1
end
